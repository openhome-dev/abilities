# Copy to .env and fill in. The CLI/library loads these automatically.
#
# Your OpenHome API key — find it at:
#   https://app.openhome.com/dashboard/settings  →  API Keys tab
OPENHOME_API_KEY=

# (Optional, for now) Browser session token, needed by the save/upload + list +
# delete endpoints until the backend accepts the API key for them.
# Grab it from the browser console on app.openhome.com:
#   copy(localStorage.getItem('access_token'))
# When set, it is used automatically for JWT-gated calls; otherwise the API key
# is sent instead (forward-compatible with the planned backend change).
OPENHOME_JWT=

# (Optional) Override the API base — e.g. a staging environment.
# OPENHOME_API_BASE=https://app.openhome.com

# (Optional) Default agent/personality id used by `openhome call` / `push`.
# OPENHOME_AGENT_ID=
