# Copy to .env and fill in. The CLI/library loads these automatically.
#
# Your OpenHome API key — find it at:
#   https://app.openhome.com/dashboard/settings  →  API Keys tab
OPENHOME_API_KEY=

# (Optional) Browser session token. NOT required — the API key above is enough
# for everything (it's sent as X-API-KEY). Only set this if you specifically want
# to act as a logged-in browser session. Grab it from the console on app.openhome.com:
#   copy(localStorage.getItem('access_token'))
OPENHOME_JWT=

# (Optional) Override the API base — e.g. a staging environment.
# OPENHOME_API_BASE=https://app.openhome.com

# (Optional) Default agent/personality id used by `openhome call` / `push`.
# OPENHOME_AGENT_ID=
